---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import BaseHead, { type Props as HeadProps } from '../components/BaseHead.astro';
import CommandPalette from '../components/CommandPalette.astro';
import Footer from '../components/Footer.astro';
import KeyboardEasterEgg from '../components/KeyboardEasterEgg.astro';
import Nav from '../components/Nav.astro';
import PostHog from '../components/PostHog.astro';
import clsx from 'clsx';
import CarbonBadge from '../components/CarbonBadge.astro';

export type Props = HeadProps & { showHeader?: boolean; fullWidth?: boolean; chrome?: boolean };

const { showHeader = true, fullWidth = false, chrome = true, ...head } = Astro.props;
---

<!doctype html>
<html lang="en" class="antialiased break-words">
    <head>
        <BaseHead {...head} />
        <ClientRouter />
        <script>
            try {
                const savedTheme = localStorage.getItem('theme');
                const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                const theme = savedTheme || (prefersDark ? 'dark' : 'light');

                document.documentElement.classList.toggle('dark', theme === 'dark');
            } catch {
                document.documentElement.classList.toggle('dark', window.matchMedia('(prefers-color-scheme: dark)').matches);
            }
        </script>

        <PostHog />

        <link rel="sitemap" href="/sitemap-index.xml" />
    </head>
    <body class="bg-main text-text text-fontPrimary">
        <a class="skip-link" href="#main-content">Skip to content</a>
        <div class="flex flex-col min-h-screen px-4 md:px-8">
            {chrome && <Nav />}

            <main id="main-content" transition:animate="fade" class={clsx('grow w-full', !fullWidth && 'max-w-5xl mx-auto')}>
                <slot />
            </main>
            {chrome && <CarbonBadge />}
            {chrome && <Footer />}
        </div>
        <CommandPalette />
        <KeyboardEasterEgg />
    </body>
</html>
