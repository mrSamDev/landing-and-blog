---
import '../styles/command-palette.css';
import type { SearchItem } from '../scripts/command-palette/types';
---

<div class="command-palette-root" data-command-palette-root hidden>
    <button class="command-palette-backdrop" type="button" aria-label="Close search" data-command-palette-close tabindex="-1"></button>
    <section
        class="command-palette"
        role="dialog"
        aria-modal="true"
        aria-labelledby="command-palette-title"
        aria-describedby="command-palette-help"
    >
        <div class="command-palette-shell">
            <header class="command-palette-header">
                <div class="command-palette-search">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path
                            d="M10.5 4a6.5 6.5 0 1 0 4.06 11.58l4.43 4.43 1.41-1.41-4.43-4.43A6.5 6.5 0 0 0 10.5 4Zm0 2a4.5 4.5 0 1 1 0 9 4.5 4.5 0 0 1 0-9Z"
                            fill="currentColor"
                        />
                    </svg>
                    <label class="sr-only" for="command-palette-input">Search the site</label>
                    <input
                        id="command-palette-input"
                        class="command-palette-input"
                        type="text"
                        autocomplete="off"
                        spellcheck="false"
                        placeholder="Search pages, posts, guides, projects, and actions"
                    />
                </div>
                <p id="command-palette-help" class="command-palette-help">Open with Cmd/Ctrl + K. Use arrows to move, Enter to open, Esc to close.</p>
            </header>

            <h2 id="command-palette-title" class="sr-only">Command palette</h2>
            <div class="command-palette-status" aria-live="polite" data-command-palette-status></div>
            <ul class="command-palette-results" role="listbox" aria-label="Search results" data-command-palette-results></ul>
            <footer class="command-palette-footer">
                <span><kbd>Enter</kbd> Open</span>
                <span><kbd>Esc</kbd> Close</span>
                <span><kbd>Up/Down</kbd> Navigate</span>
            </footer>
        </div>
    </section>
</div>

<script>
    import { initCommandPalette } from '../scripts/command-palette';

    initCommandPalette();
</script>
