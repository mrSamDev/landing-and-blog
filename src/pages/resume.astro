                </article>

            </div>
        </section>

        <section class="mb-9">
            <h2 class="text-xs font-semibold uppercase tracking-widest text-fontPrimary/50 border-b border-fontPrimary/20 pb-2 mb-4">Certifications</h2>
            <ul class="space-y-2 text-sm text-fontPrimary/85">
                <li class="pl-4 border-l-2 border-fontPrimary/15">Certified Scrum Master (CSM) — Scrum Alliance</li>
                <li class="pl-4 border-l-2 border-fontPrimary/15">Certified Secure Web Application Engineer (CSWAE) — Mile2</li>
            </ul>
        </section>

