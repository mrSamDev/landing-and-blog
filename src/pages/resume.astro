<BaseLayout title="Resume" description="Sijo Sam's resume — Technical Lead & Full-Stack Engineer">
    <article class="max-w-3xl mx-auto mb-16 sm:mb-24 px-2">

        <header class="mb-8 pt-6">
    
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
                <div>
                    <h1 class="text-3xl font-bold text-fontPrimary">Sijo Sam</h1>
                    <p class="text-lg text-fontPrimary/70 mt-0.5">Technical Lead &amp; Full-Stack Engineer</p>

                    <div class="mt-3 space-y-0.5 text-sm text-fontPrimary/70">
                        <p>Kerala, India</p>
                    </div>

                    <div class="mt-3 flex flex-wrap gap-x-3 gap-y-1 text-sm">
                        <a href="mailto:dev.sijo.sam@gmail.com" class="text-fontPrimary/70 hover:text-fontPrimary underline decoration-dashed">dev.sijo.sam@gmail.com</a>
                        <a href="https://www.sijosam.com/" target="_blank" rel="noopener noreferrer" class="text-fontPrimary/70 hover:text-fontPrimary underline decoration-dashed">sijosam.com</a>
