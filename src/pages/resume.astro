---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects, skillGroups, workExperience } from '../data/resume';
---

<BaseLayout title="Resume" description="Sijo Sam's resume — Technical Lead & Full-Stack Engineer">
    <article class="max-w-3xl mx-auto mb-16 sm:mb-24 px-2">

        <header class="mb-8 pt-6">
    
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
                <div>
                    <h1 class="text-3xl font-bold text-fontPrimary">Sijo Sam</h1>
                    <p class="text-lg text-fontPrimary/70 mt-0.5">Technical Lead &amp; Full-Stack Engineer</p>

                    <div class="mt-3 space-y-0.5 text-sm text-fontPrimary/70">
                        <p>Kerala, India</p>
                    </div>

                    <div class="mt-3 flex flex-wrap gap-x-3 gap-y-1 text-sm">
                        <a href="mailto:dev.sijo.sam@gmail.com" class="text-fontPrimary/70 hover:text-fontPrimary underline decoration-dashed">dev.sijo.sam@gmail.com</a>
                        <a href="https://www.sijosam.com/" target="_blank" rel="noopener noreferrer" class="text-fontPrimary/70 hover:text-fontPrimary underline decoration-dashed">sijosam.com</a>
                        <a href="https://www.linkedin.com/in/sijo-sam/" target="_blank" rel="noopener noreferrer" class="text-fontPrimary/70 hover:text-fontPrimary underline decoration-dashed">LinkedIn</a>
                        <a href="https://github.com/mrSamDev" target="_blank" rel="noopener noreferrer" class="text-fontPrimary/70 hover:text-fontPrimary underline decoration-dashed">GitHub</a>
                    </div>
                </div>

            
            </div>
        </header>

        <section class="mb-9">
            <h2 class="text-xs font-semibold uppercase tracking-widest text-fontPrimary/50 border-b border-fontPrimary/20 pb-2 mb-4">Professional Summary</h2>
            <p class="text-base text-fontPrimary/85 leading-relaxed">
                Technical Lead and Full-Stack Engineer with 8+ years of experience designing and delivering scalable web platforms across frontend and backend systems. Skilled in React, TypeScript, Node.js, and Python, with expertise in building data-driven dashboards, distributed APIs, and high-performance applications. Experienced in leading engineering teams, modernizing legacy systems, and driving performance improvements that increased search visibility by 50% and reduced development time by 30%.
            </p>
            <p class="mt-3 text-sm text-fontPrimary/70">Open to international relocation.</p>
        </section>

        <section class="mb-9">
            <h2 class="text-xs font-semibold uppercase tracking-widest text-fontPrimary/50 border-b border-fontPrimary/20 pb-2 mb-4">Technologies &amp; Skills</h2>
            <div class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-2 text-sm">
                {skillGroups.map(([label, value]) => (
                    <div class="contents">
                        <span class="font-semibold text-fontPrimary whitespace-nowrap">{label}</span>
                        <span class="text-fontPrimary/80">{value}</span>
                    </div>
                ))}
            </div>
        </section>

        <section class="mb-9">
            <h2 class="text-xs font-semibold uppercase tracking-widest text-fontPrimary/50 border-b border-fontPrimary/20 pb-2 mb-5">Work Experience</h2>
            <div class="space-y-8">
                {workExperience.map((entry) => (
                    <article class="pl-4 border-l-2 border-fontPrimary/15">
                        <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5 mb-1">
                            <div>
                                <span class="font-semibold text-fontPrimary">{entry.role}</span>
                                <span class="text-fontPrimary/40 mx-1.5">·</span>
                                <span class="font-medium text-fontPrimary/70">{entry.company}</span>
                            </div>
                            <span class="text-xs text-fontPrimary/50 shrink-0">{entry.period}</span>
                        </div>
                        <p class="text-xs text-fontPrimary/50 mb-3">{entry.location}</p>
                        <ul class="list-disc ml-4 space-y-1.5 text-sm text-fontPrimary/85 leading-relaxed">
                            {entry.achievements.map((item) => <li>{item}</li>)}
                        </ul>
                        <p class="mt-3 text-xs text-fontPrimary/65">Technologies: {entry.technologies}</p>
                    </article>
                ))}
            </div>
        </section>

        <section class="mb-9">
            <h2 class="text-xs font-semibold uppercase tracking-widest text-fontPrimary/50 border-b border-fontPrimary/20 pb-2 mb-4">Education</h2>
            <div class="pl-4 border-l-2 border-fontPrimary/15 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5">
                <div>
                    <p class="font-semibold text-fontPrimary text-sm">Bachelor of Technology in Computer Science</p>
                    <p class="text-sm text-fontPrimary/70 mt-0.5">University of Cochin, India</p>
                </div>
                <span class="text-xs text-fontPrimary/50 shrink-0">2014 – 2018</span>
            </div>
        </section>

        <section class="mb-9">
            <h2 class="text-xs font-semibold uppercase tracking-widest text-fontPrimary/50 border-b border-fontPrimary/20 pb-2 mb-5">Projects &amp; Open Source</h2>
            <div class="space-y-6">
                {projects.map((project) => (
                    <article class="pl-4 border-l-2 border-fontPrimary/15">
                        <div class="flex items-baseline gap-2 mb-2">
                            <span class="font-semibold text-fontPrimary">{project.title}</span>
                            <span class="text-xs text-fontPrimary/50">{project.label}</span>
                            <a href={project.href} target="_blank" rel="noopener noreferrer" class="text-xs text-fontPrimary/50 hover:text-fontPrimary underline decoration-dashed ml-auto">{project.hrefLabel}</a>
                        </div>
                        {project.description && <p class="text-sm text-fontPrimary/85 leading-relaxed">{project.description}</p>}
                        {project.achievements && (
                            <ul class="list-disc ml-4 space-y-1.5 text-sm text-fontPrimary/85 leading-relaxed">
                                {project.achievements.map((item) => <li>{item}</li>)}
                            </ul>
                        )}
                        {project.technologies && <p class="mt-3 text-xs text-fontPrimary/65">Technologies: {project.technologies}</p>}
                    </article>
                ))}
            </div>
        </section>

        <section class="mb-9">
            <h2 class="text-xs font-semibold uppercase tracking-widest text-fontPrimary/50 border-b border-fontPrimary/20 pb-2 mb-4">Certifications</h2>
            <ul class="space-y-2 text-sm text-fontPrimary/85">
                <li class="pl-4 border-l-2 border-fontPrimary/15">Certified Scrum Master (CSM) — Scrum Alliance</li>
                <li class="pl-4 border-l-2 border-fontPrimary/15">Certified Secure Web Application Engineer (CSWAE) — Mile2</li>
            </ul>
        </section>

    </article>
</BaseLayout>

<style>
    @media print {
        button { display: none !important; }
        article { max-width: 100% !important; }
    }
</style>
