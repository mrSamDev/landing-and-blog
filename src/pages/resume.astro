---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Resume" description="Sijo Sam's resume">
    <article class="mb-16 sm:mb-24">
       
        <div class="w-full">
            <iframe
                src="https://docs.google.com/document/d/e/2PACX-1vTlds-VrcgsjzqxprzoACiJ8nkRTB3u27l6qGFA48dcHcYVlxNLnvXBN48UzDH4v23OzhPZEj3NJzP8/pub?embedded=true"
                class="w-full border-0"
                style="height: 850px;"
                title="Sijo Sam Resume"
                loading="lazy"
            ></iframe>
            <p class="mt-4 text-sm text-center">
                <a
                    href="https://docs.google.com/document/d/e/2PACX-1vTlds-VrcgsjzqxprzoACiJ8nkRTB3u27l6qGFA48dcHcYVlxNLnvXBN48UzDH4v23OzhPZEj3NJzP8/pub"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline"
                >
                    Open in Google Docs
                </a>
            </p>
        </div>
    </article>
</BaseLayout>
