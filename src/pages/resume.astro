                <article class="pl-4 border-l-2 border-fontPrimary/15">
                    <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5 mb-1">
                        <div>
                            <span class="font-semibold text-fontPrimary">Technical Lead</span>
                            <span class="text-fontPrimary/40 mx-1.5">·</span>
                            <span class="font-medium text-fontPrimary/70">Gadgeon</span>
